{
  "name": "drill3",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "explain": "tsx src/explain.ts",
    "db:reset": "psql $DATABASE_URL -c 'DROP TABLE IF EXISTS users;'",
    "db:setup": "psql $DATABASE_URL -c 'CREATE TABLE IF NOT EXISTS users(id SERIAL PRIMARY KEY, email TEXT);'",
    "db:index": "psql $DATABASE_URL -c 'CREATE INDEX IF NOT EXISTS idx_users_email ON users(email);'",
    "db:drop-index": "psql $DATABASE_URL -c 'DROP INDEX IF EXISTS idx_users_email;'"
  },
